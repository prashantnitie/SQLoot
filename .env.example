# Copy to .env and fill in your keys:
#   copy .env.example .env
#
# Load order (first wins): shell env > .env > local.settings.json Values

# Data source: "local" (JSON in data/) or "live" (Coral SQL)
DATA_SOURCE=local

GROQ_API_KEY=gsk_your_groq_key_here
# Optional: defaults to llama-3.3-70b-versatile, auto-falls back to llama-3.1-8b-instant on rate limit
# GROQ_MODEL=llama-3.1-8b-instant
INTERCOM_ACCESS_TOKEN=your_intercom_access_token
STRIPE_SECRET_KEY=sk_test_or_rk_test_your_stripe_key
